# Copy to .env and fill values. Used by docker-compose.yml (same variables as deploy.yml + code).
#
# Before first up:
#   docker volume create pyrogram-sessions
#
# --- PostgreSQL (main app DB: backend, ai-core, message-processor) ---
POSTGRESQL_HOST=postgresql
POSTGRESQL_PORT=5432
POSTGRESQL_DB=cardinal
POSTGRESQL_USER=cardinal
POSTGRESQL_PASS=

# --- PostgreSQL (embeddings-processor only) ---
# Must match EMBEDDINGS_PROCESSOR_DB_CONNECTION_STRING (same user/db/password).
EMBEDDINGS_POSTGRESQL_DB=cardinal
EMBEDDINGS_POSTGRESQL_USER=cardinal
EMBEDDINGS_PROCESSOR_POSTGRESQL_PASS=
# Npgsql-style connection string for the embeddings C# service
EMBEDDINGS_PROCESSOR_DB_CONNECTION_STRING=Host=embeddings-postgresql;Port=5432;Database=cardinal;Username=cardinal;Password=

# --- RabbitMQ ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_USER=cardinal
RABBITMQ_PASS=

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Qdrant (API key for server + clients) ---
QDRANT_KEY=

# --- Internal service URLs (defaults match docker-compose service names) ---
BACKEND_CORE_HOST=http://backend-core:8000
EMBEDDINGS_PROCESSOR_HOST=http://embeddings-processor:8080
AI_CORE_HOST=http://ai-core:8000
# C# app: Qdrant HTTP URL inside the stack
QDRANT_APP_HOST=http://qdrant:6333
# C# app: text-embeddings-inference URL inside the stack
EMBEDDINGS_API_HOST=http://embeddings:80

# --- Inter-service API keys (shared secrets between services) ---
# backend-core receives this as API_KEY; message-processor calls backend with this header
BACKEND_CORE_KEY=
AI_CORE_KEY=
EMBEDDINGS_PROCESSOR_KEY=

# --- Auth / JWT ---
SECURITY_KEY=

# --- Telegram bots ---
BOT_TOKEN=
RECOMMENDATION_BOT_TOKEN=
# Public HTTPS base for webhooks (no trailing slash required; app normalizes)
WEBHOOK_URL=https://cardinal-x.online
# Secret for Telegram webhook setup; passed to backend as WEBHOOK_KEY
TG_WEBHOOK_KEY=

# --- Telegram client (Pyrogram / telegram-parser) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Comma-separated session names folder prefix; code reads PYRO_SESSIONS (deploy.yml used PYRO_SESSION — align with code)
PYRO_SESSIONS=cardinal
CHECK_DUPLICATES=false
ENABLE_PULL=true

# --- OpenAI / DeepSeek / LangSmith ---
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MIN_CONFIDENCE=0.5
AI_MODE=prod
AI_VERSION=gpt-4.1-mini
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=cardinal
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- Payments (backend-core) ---
ALPHA_KEY=
LAVA_KEY=
# Maps to backend env LAVA_X_KEY
LAVA_WEBHOOK_KEY=
ROBOKASSA_PASS_1=
ROBOKASSA_PASS_2=
ROBOKASSA_TEST=false

# --- Selarti integration (backend-core) ---
SELARTI_AUTH_HOST=
SELARTI_TARGET_HOST=
SELARTI_KEY=
SELARTI_TASK=

# --- Observability ---
ENABLE_METRICS=false

# --- message-processor tuning ---
QUEUE_TASKS=50

# --- embeddings-processor (.NET) optional overrides ---
EMBEDDINGS_ASPNETCORE_ENVIRONMENT=Production
QDRANT_COLLECTION_NAME=leads
EMBEDDINGS_SEARCH_SCORE_THRESHOLD=0.86
SEARCH_TOPN=1000
SEARCH_BAYESIAN_ALPHA=1.0
SEARCH_BAYESIAN_BETA=1.0
SEARCH_MIN_GROUP_SCORE_SUM_THRESHOLD=0.6
SEARCH_POOLING_MODE=max

# --- Frontend build (Vite; used when building app image / local npm run build, not runtime in prebuilt container) ---
VITE_BACKEND_BASE_URL=https://cardinal-x.online/api
VITE_AI_CORE_BASE_URL=https://ai.cardinal-x.online/api
VITE_USE_HTTPS=false
