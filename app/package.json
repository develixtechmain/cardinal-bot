{
  "name": "telegram-mini-app",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.20.0 <23.0.0",
    "npm": ">=10.9.3 <11.0.0"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "serve": "^14.2.5",
    "wouter": "^3.7.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^24.6.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/telegram-web-app": "^7.10.1",
    "@vitejs/plugin-react": "^5.0.4",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.2",
    "typed-css-modules": "^0.9.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vite-plugin-svgr": "^4.5.0"
  },
  "scripts": {
    "dev": "npm-run-all --parallel client css:watch:pages css:watch:components",
    "client": "vite",
    "css:gen": "tcm src --include '**/*.module.css'",
    "css:watch:pages": "tcm src/pages --include '**/*.module.css' --watch",
    "css:watch:components": "tcm src/components --include '**/*.module.css' --watch",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "build": "npm run css:gen && vite build",
    "start": "npx serve -s dist -l 5173"
  },
  "browserslist": {
    "production": [
      "Android >= 6",
      "iOS >= 12"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
