{
  "compilerOptions": {
    "resolveJsonModule": true,
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["dom", "esnext"],
    "strict": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "jsx": "react-jsx",
    "forceConsistentCasingInFileNames": true,
    "typeRoots": ["node_modules/@types","types","./node_modules/@types", "./src/types"]
  },
  "include": [
    "src",
    "vite.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
